DISCORD_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_discord_application_client_id
DISCORD_GUILD_ID=your_main_server_id_for_management_commands
BOT_OWNER_ID=your_discord_user_id

# Optional: enable AI chat replies when users mention the bot.
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4.1-mini

# Required for /weather.
OPENWEATHER_API_KEY=your_openweather_api_key

# Optional: YouTube cookies for yt-dlp when cloud hosts are challenged by YouTube.
# Keep cookies.txt outside Git and point this to the host-local file path.
YTDLP_COOKIES_PATH=

# Optional: 吉幣 SQLite database. Keep this file out of Git.
COIN_DB_PATH=data/xiaoji.sqlite
COIN_TIMEZONE=Asia/Taipei
