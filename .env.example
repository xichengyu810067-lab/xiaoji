DISCORD_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_discord_application_client_id
DISCORD_GUILD_ID=your_main_server_id_for_management_commands
BOT_OWNER_ID=your_discord_user_id
# Legacy fallback only. Prefer BOT_OWNER_ID for new deployments.
OWNER_ID=

# Optional: enable AI chat replies when users mention the bot.
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4.1-mini

# Required for /weather.
OPENWEATHER_API_KEY=your_openweather_api_key

# Optional: custom Lavalink node for /music play.
# If omitted, Xiaoji attempts the built-in public fallback nodes, which may be less reliable.
LAVALINK_HOST=
LAVALINK_PORT=2333
LAVALINK_PASSWORD=
LAVALINK_SECURE=false
LAVALINK_NODE_NAME=CustomNode

# Optional: 吉幣 SQLite database. Keep this file out of Git.
COIN_DB_PATH=data/xiaoji.sqlite
COIN_TIMEZONE=Asia/Taipei
